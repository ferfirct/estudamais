PORT=3333
FRONTEND_ORIGIN=http://localhost:5173

# Groq — chave gratuita em https://console.groq.com
GROQ_API_KEY=sua_chave_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# JWT — gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-por-string-longa-e-aleatoria
JWT_EXPIRES_IN=7d

# SQLite — path do banco (em Docker usa /app/data/estuda.db)
DB_PATH=./estuda.db
