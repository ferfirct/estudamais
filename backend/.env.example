PORT=3333
FRONTEND_ORIGIN=http://localhost:5173

# Groq — chave gratuita em https://console.groq.com
GROQ_API_KEY=
# Opcional: várias chaves separadas por vírgula para fallback automático em caso de quota esgotada (429)
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile

# JWT — gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# SQLite — path do banco (em Docker usa /app/data/estuda.db)
DB_PATH=./estuda.db

# Usado apenas por `npm run seed:admin` para criar o usuário admin inicial
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin
